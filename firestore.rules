rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function ownsExistingWorkspace() {
      return isAuthenticated() && resource.data.workspaceId == request.auth.uid;
    }

    function ownsIncomingWorkspace() {
      return isAuthenticated() && request.resource.data.workspaceId == request.auth.uid;
    }

    function preservesWorkspaceOwnership() {
      return ownsExistingWorkspace() && ownsIncomingWorkspace();
    }

    match /claims/{claimId} {
      allow get, delete: if ownsExistingWorkspace();
      allow list: if isAuthenticated();
      allow create: if ownsIncomingWorkspace();
      allow update: if preservesWorkspaceOwnership();
    }

    match /denials/{denialId} {
      allow get, delete: if ownsExistingWorkspace();
      allow list: if isAuthenticated();
      allow create: if ownsIncomingWorkspace();
      allow update: if preservesWorkspaceOwnership();
    }

    match /appealTemplates/{carcCode} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
