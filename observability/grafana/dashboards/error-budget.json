{
  "title": "Phase Runner Error Budget",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "2m",
  "panels": [
    {
      "type": "stat",
      "title": "Burn events (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(phase_runner_error_budget_burn_total[24h]))",
          "legendFormat": "burn"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Burn rate (1h)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(phase_runner_error_budget_burn_total[1h]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      }
    }
  ]
}
